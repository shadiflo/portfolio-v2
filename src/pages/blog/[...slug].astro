---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProfileCard from '../../components/ProfileCard.astro';
import { getCollection } from 'astro:content';
import { getCategoryBySlug } from '../../data/categories';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const cat = getCategoryBySlug(post.data.category);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${post.data.title} — Florin`} description={post.data.description}>
  <Header />

  <div class="mx-auto max-w-7xl px-4 py-6">
    <div class="flex flex-col gap-6 lg:flex-row">

      <!-- LEFT: Post content -->
      <main class="flex-1 min-w-0">
        <article class="rounded-lg border border-surface-border bg-surface p-6 md:p-8">
          <!-- Back link -->
          <a href="/blog" class="mb-4 inline-flex items-center gap-1 text-sm text-text-muted hover:text-accent transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
            </svg>
            Back to posts
          </a>

          <!-- Header -->
          <div class="mb-6">
            <div class="mb-3 flex items-center gap-2">
              {cat && (
                <span
                  class="rounded px-2 py-0.5 text-xs font-semibold"
                  style={`background: ${cat.color}20; color: ${cat.color};`}
                >
                  {cat.label}
                </span>
              )}
              <span class="text-xs text-text-muted">{formattedDate}</span>
              <span class="text-xs text-text-muted">&middot;</span>
              <span class="text-xs text-text-muted">by {post.data.author}</span>
            </div>
            <h1 class="text-2xl font-bold text-text-primary md:text-3xl leading-tight">{post.data.title}</h1>
            <p class="mt-2 text-text-secondary">{post.data.description}</p>
          </div>

          {post.data.image && (
            <img
              src={post.data.image}
              alt={post.data.title}
              class="mb-6 w-full rounded-lg object-cover"
            />
          )}

          <!-- Tags -->
          {post.data.tags.length > 0 && (
            <div class="mb-6 flex flex-wrap gap-1">
              {post.data.tags.map((tag: string) => (
                <span class="rounded bg-navy-800 px-2 py-0.5 text-xs text-text-muted">{tag}</span>
              ))}
            </div>
          )}

          <!-- Markdown content -->
          <div class="prose">
            <Content />
          </div>
        </article>
      </main>

      <!-- RIGHT: Sidebar -->
      <aside class="w-full shrink-0 lg:w-80">
        <div class="sticky top-20 space-y-4">
          <ProfileCard />
        </div>
      </aside>

    </div>
  </div>

  <Footer />
</BaseLayout>
