---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ProfileCard from '../components/ProfileCard.astro';
import { projects } from '../data/projects';
---

<BaseLayout title="Projects — Florin">
  <Header />

  <div class="mx-auto max-w-7xl px-4 py-6">
    <div class="flex flex-col gap-6 lg:flex-row">

      <main class="flex-1 min-w-0">
        <h1 class="mb-4 text-2xl font-bold text-text-primary">Projects</h1>
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project) => (
            <div>
              {project.url ? (
                <a
                  href={project.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group block h-full rounded-lg border border-surface-border bg-surface p-5 transition-all hover:border-navy-500 hover:bg-surface-hover"
                >
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="text-base font-semibold text-text-primary group-hover:text-accent transition-colors">
                      {project.title}
                    </h3>
                    <svg class="h-4 w-4 shrink-0 text-text-muted opacity-0 group-hover:opacity-100 transition-opacity mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M7 17L17 7M17 7H7M17 7v10" />
                    </svg>
                  </div>
                  <p class="mt-2 text-sm text-text-secondary leading-relaxed">{project.description}</p>
                  {project.stack.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1">
                      {project.stack.map((tech) => (
                        <span class="rounded bg-navy-800 px-2 py-0.5 text-xs text-text-muted">{tech}</span>
                      ))}
                    </div>
                  )}
                </a>
              ) : (
                <div class="h-full rounded-lg border border-surface-border bg-surface p-5">
                  <h3 class="text-base font-semibold text-text-primary">{project.title}</h3>
                  <p class="mt-2 text-sm text-text-secondary leading-relaxed">{project.description}</p>
                  {project.stack.length > 0 && (
                    <div class="mt-3 flex flex-wrap gap-1">
                      {project.stack.map((tech) => (
                        <span class="rounded bg-navy-800 px-2 py-0.5 text-xs text-text-muted">{tech}</span>
                      ))}
                    </div>
                  )}
                </div>
              )}
            </div>
          ))}
        </div>
      </main>

      <aside class="w-full shrink-0 lg:w-80">
        <div class="sticky top-20">
          <ProfileCard />
        </div>
      </aside>

    </div>
  </div>

  <Footer />
</BaseLayout>
