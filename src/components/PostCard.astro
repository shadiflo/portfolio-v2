---
import { getCategoryBySlug } from '../data/categories';

interface Props {
  title: string;
  description: string;
  date: Date;
  category: string;
  slug: string;
  image?: string;
  tags?: string[];
}

const { title, description, date, category, slug, image, tags = [] } = Astro.props;
const cat = getCategoryBySlug(category);

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric',
});
---

<a href={`/blog/${slug}`} class="group block">
  <article class="rounded-lg border border-surface-border bg-surface p-4 transition-all hover:border-navy-500 hover:bg-surface-hover">
    <!-- Optional image -->
    {image && (
      <div class="mb-3 overflow-hidden rounded-md">
        <img
          src={image}
          alt={title}
          class="h-40 w-full object-cover transition-transform duration-300 group-hover:scale-105"
        />
      </div>
    )}

    <!-- Category + date -->
    <div class="mb-2 flex items-center gap-2">
      {cat && (
        <span
          class="rounded px-2 py-0.5 text-xs font-semibold"
          style={`background: ${cat.color}20; color: ${cat.color};`}
        >
          {cat.label}
        </span>
      )}
      <span class="text-xs text-text-muted">{formattedDate}</span>
    </div>

    <!-- Title -->
    <h3 class="mb-1 text-base font-semibold text-text-primary group-hover:text-accent transition-colors leading-snug">
      {title}
    </h3>

    <!-- Description -->
    <p class="text-sm text-text-secondary line-clamp-2 leading-relaxed">
      {description}
    </p>

    <!-- Tags -->
    {tags.length > 0 && (
      <div class="mt-3 flex flex-wrap gap-1">
        {tags.slice(0, 3).map((tag) => (
          <span class="rounded bg-navy-800 px-2 py-0.5 text-xs text-text-muted">
            {tag}
          </span>
        ))}
      </div>
    )}
  </article>
</a>
